# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Nome do bucket privado de storage (criado no Supabase Storage)
SUPABASE_STORAGE_BUCKET=casal-memorias

# Segredo usado para assinar os cookies de sessao (gere uma string aleatoria longa)
# Ex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-por-uma-string-aleatoria-bem-longa

# Hashes de senha (gerados com "npm run hash-password").
# Sao usados apenas no PRIMEIRO acesso para popular a tabela app_settings.
# Depois disso a senha fica salva (com hash) no banco e pode ser trocada pela tela de Configuracoes.
APP_PASSWORD_HASH=
PRIVATE_AREA_PASSWORD_HASH=
